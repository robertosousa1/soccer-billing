####################################
# Banco
####################################
# DATABASE_URL = conexão usada em runtime pela API. DIRECT_URL = conexão usada só por
# `prisma migrate dev/deploy`. Em dev as duas são iguais (sem pooler); em produção
# DATABASE_URL passa pelo pgcat e DIRECT_URL continua direto no Postgres real.

# DEV (ativo): direto no Postgres do docker-compose.yml da raiz, sem pooler
DATABASE_URL="postgresql://pelada:pelada@localhost:5432/pelada?schema=public"
DIRECT_URL="postgresql://pelada:pelada@localhost:5432/pelada?schema=public"

# PROD (referência, não usar em dev): atrás do pgcat — ver infra/pgcat/README.md
# DATABASE_URL="postgresql://user:pass@PGCAT_HOST:6432/pelada?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://user:pass@DB_HOST:5432/pelada"

####################################
# Auth
####################################
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

####################################
# Fila / Redis (obrigatório — BullMQ)
####################################
REDIS_URL="redis://localhost:6379"

####################################
# Storage do extrato bruto (auditoria)
####################################
STORAGE_DRIVER="local"            # "local" em dev; "s3" em produção
STORAGE_LOCAL_DIR="./storage"
S3_BUCKET=""
S3_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

####################################
# Observabilidade (obrigatório em produção; vazio desativa em dev)
####################################
SENTRY_DSN=""
NEW_RELIC_LICENSE_KEY=""
NEW_RELIC_APP_NAME="pelada-api"

####################################
# E-mail
####################################
EMAIL_API_KEY=""
EMAIL_FROM=""
APP_URL="http://localhost:3000/"

####################################
# reCAPTCHA v3
####################################
RECAPTCHA_SECRET_KEY=""

####################################
# App
####################################
PORT=3333
NODE_ENV=development
